{"allContent":{"docusaurus-plugin-css-cascade-layers":{},"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/promptbio-wiki/docs","tagsPath":"/promptbio-wiki/docs/tags","isLast":true,"routePriority":-1,"sidebarFilePath":"/Users/shishirhebbar/shishir/promptbio/promptbio-wiki-demo/docusaurus-site/sidebars.ts","contentPath":"/Users/shishirhebbar/shishir/promptbio/promptbio-wiki-demo/docusaurus-site/docs","docs":[{"id":"general/Analysis/comparative-analysis","title":"Comparative Analysis","description":"Comparative analysis in PromptBio allows you to compare gene expression, protein levels, or other biological measurements across two or more groups.","source":"@site/docs/general/Analysis/Comparative_analysis.md","sourceDirName":"general/Analysis","slug":"/general/Analysis/comparative-analysis","permalink":"/promptbio-wiki/docs/general/Analysis/comparative-analysis","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"comparative-analysis","title":"Comparative Analysis","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Differential Analysis","permalink":"/promptbio-wiki/docs/general/Analysis/differential-analysis"},"next":{"title":"Functional Enrichment","permalink":"/promptbio-wiki/docs/general/Analysis/functional-enrichment"}},{"id":"general/Analysis/differential-analysis","title":"Differential Analysis","description":"Differential analysis identifies features (genes, proteins, metabolites) that are statistically significantly different between two conditions.","source":"@site/docs/general/Analysis/Differential_analysis.md","sourceDirName":"general/Analysis","slug":"/general/Analysis/differential-analysis","permalink":"/promptbio-wiki/docs/general/Analysis/differential-analysis","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"id":"differential-analysis","title":"Differential Analysis","sidebar_position":2},"sidebar":"generalSidebar","previous":{"title":"Data Management","permalink":"/promptbio-wiki/docs/general/Data/data-overview"},"next":{"title":"Comparative Analysis","permalink":"/promptbio-wiki/docs/general/Analysis/comparative-analysis"}},{"id":"general/Analysis/functional-enrichment","title":"Functional Enrichment","description":"Functional enrichment analysis helps you understand the biological meaning behind a list of significant genes or proteins by mapping them to known pathways and gene ontology (GO) terms.","source":"@site/docs/general/Analysis/Functional_enrichment.md","sourceDirName":"general/Analysis","slug":"/general/Analysis/functional-enrichment","permalink":"/promptbio-wiki/docs/general/Analysis/functional-enrichment","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"id":"functional-enrichment","title":"Functional Enrichment","sidebar_position":3},"sidebar":"generalSidebar","previous":{"title":"Comparative Analysis","permalink":"/promptbio-wiki/docs/general/Analysis/comparative-analysis"},"next":{"title":"Multi-Group Comparison","permalink":"/promptbio-wiki/docs/general/Analysis/multi-group-comparison"}},{"id":"general/Analysis/multi-group-comparison","title":"Multi-Group Comparison","description":"Multi-group comparison extends differential analysis to handle three or more groups simultaneously, using ANOVA-like approaches for biological data.","source":"@site/docs/general/Analysis/Multi-group_comparison.md","sourceDirName":"general/Analysis","slug":"/general/Analysis/multi-group-comparison","permalink":"/promptbio-wiki/docs/general/Analysis/multi-group-comparison","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"id":"multi-group-comparison","title":"Multi-Group Comparison","sidebar_position":4},"sidebar":"generalSidebar","previous":{"title":"Functional Enrichment","permalink":"/promptbio-wiki/docs/general/Analysis/functional-enrichment"},"next":{"title":"Single-Cell Clustering","permalink":"/promptbio-wiki/docs/general/Analysis/single-cell-clustering"}},{"id":"general/Analysis/single-cell-clustering","title":"Single-Cell Clustering","description":"Single-cell clustering groups individual cells by their expression profiles to identify distinct cell populations within your dataset.","source":"@site/docs/general/Analysis/Single-cell_clustering.md","sourceDirName":"general/Analysis","slug":"/general/Analysis/single-cell-clustering","permalink":"/promptbio-wiki/docs/general/Analysis/single-cell-clustering","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"id":"single-cell-clustering","title":"Single-Cell Clustering","sidebar_position":5},"sidebar":"generalSidebar","previous":{"title":"Multi-Group Comparison","permalink":"/promptbio-wiki/docs/general/Analysis/multi-group-comparison"},"next":{"title":"MLGenie Overview","permalink":"/promptbio-wiki/docs/general/MLGenie/mlgenie-overview"}},{"id":"general/Data/data-overview","title":"Data Management","description":"This section explains how to upload, format, and manage your biological data in PromptBio.","source":"@site/docs/general/Data/overview.md","sourceDirName":"general/Data","slug":"/general/Data/data-overview","permalink":"/promptbio-wiki/docs/general/Data/data-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"data-overview","title":"Data Management","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Project Management","permalink":"/promptbio-wiki/docs/general/Project/project-overview"},"next":{"title":"Differential Analysis","permalink":"/promptbio-wiki/docs/general/Analysis/differential-analysis"}},{"id":"general/general-overview","title":"General Documentation","description":"This section contains high-level guides for all PromptBio modules. Choose a module below to get started.","source":"@site/docs/general/index.md","sourceDirName":"general","slug":"/general/","permalink":"/promptbio-wiki/docs/general/","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"general-overview","title":"General Documentation","sidebar_position":1}},{"id":"general/Home/getting-started","title":"Getting Started","description":"Welcome! This guide walks you through everything you need to start analyzing biological data in PromptBio.","source":"@site/docs/general/Home/getting-started.md","sourceDirName":"general/Home","slug":"/general/Home/getting-started","permalink":"/promptbio-wiki/docs/general/Home/getting-started","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"getting-started","title":"Getting Started","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Welcome","permalink":"/promptbio-wiki/docs/intro"},"next":{"title":"Project Management","permalink":"/promptbio-wiki/docs/general/Project/project-overview"}},{"id":"general/MarkerGenie/markergenie-overview","title":"MarkerGenie Overview","description":"MarkerGenie automates biomarker discovery by combining statistical testing, machine learning, and biological database lookups to identify the most meaningful features in your dataset.","source":"@site/docs/general/MarkerGenie/overview.md","sourceDirName":"general/MarkerGenie","slug":"/general/MarkerGenie/markergenie-overview","permalink":"/promptbio-wiki/docs/general/MarkerGenie/markergenie-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"markergenie-overview","title":"MarkerGenie Overview","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"MLGenie Overview","permalink":"/promptbio-wiki/docs/general/MLGenie/mlgenie-overview"},"next":{"title":"NotebookGenie Overview","permalink":"/promptbio-wiki/docs/general/NotebookGenie/notebookgenie-overview"}},{"id":"general/MLGenie/mlgenie-overview","title":"MLGenie Overview","description":"MLGenie is PromptBio's machine learning module that enables you to build, train, and evaluate predictive models on biological datasets — no coding required.","source":"@site/docs/general/MLGenie/overview.md","sourceDirName":"general/MLGenie","slug":"/general/MLGenie/mlgenie-overview","permalink":"/promptbio-wiki/docs/general/MLGenie/mlgenie-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"mlgenie-overview","title":"MLGenie Overview","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Single-Cell Clustering","permalink":"/promptbio-wiki/docs/general/Analysis/single-cell-clustering"},"next":{"title":"MarkerGenie Overview","permalink":"/promptbio-wiki/docs/general/MarkerGenie/markergenie-overview"}},{"id":"general/NotebookGenie/notebookgenie-overview","title":"NotebookGenie Overview","description":"NotebookGenie generates ready-to-run Jupyter notebooks from your PromptBio analyses. It lets bioinformaticians take any analysis run inside PromptBio and export it as reproducible, annotated Python code.","source":"@site/docs/general/NotebookGenie/overview.md","sourceDirName":"general/NotebookGenie","slug":"/general/NotebookGenie/notebookgenie-overview","permalink":"/promptbio-wiki/docs/general/NotebookGenie/notebookgenie-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"notebookgenie-overview","title":"NotebookGenie Overview","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"MarkerGenie Overview","permalink":"/promptbio-wiki/docs/general/MarkerGenie/markergenie-overview"},"next":{"title":"Omics Overview","permalink":"/promptbio-wiki/docs/general/Omics/omics-overview"}},{"id":"general/Omics/omics-overview","title":"Omics Overview","description":"The Omics module in PromptBio allows you to integrate and analyze data across multiple biological layers — genomics, transcriptomics, proteomics, and metabolomics — in a single workflow.","source":"@site/docs/general/Omics/overview.md","sourceDirName":"general/Omics","slug":"/general/Omics/omics-overview","permalink":"/promptbio-wiki/docs/general/Omics/omics-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"omics-overview","title":"Omics Overview","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"NotebookGenie Overview","permalink":"/promptbio-wiki/docs/general/NotebookGenie/notebookgenie-overview"},"next":{"title":"Workflow Overview","permalink":"/promptbio-wiki/docs/general/Workflow/workflow-overview"}},{"id":"general/Project/project-overview","title":"Project Management","description":"Projects are the top-level workspace in PromptBio. All your data, analyses, and results are organized within a project.","source":"@site/docs/general/Project/overview.md","sourceDirName":"general/Project","slug":"/general/Project/project-overview","permalink":"/promptbio-wiki/docs/general/Project/project-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"project-overview","title":"Project Management","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Getting Started","permalink":"/promptbio-wiki/docs/general/Home/getting-started"},"next":{"title":"Data Management","permalink":"/promptbio-wiki/docs/general/Data/data-overview"}},{"id":"general/Workflow/workflow-overview","title":"Workflow Overview","description":"Workflows let you chain multiple PromptBio analyses together into a single automated pipeline. Instead of running each step manually, you define the steps once and run them end-to-end.","source":"@site/docs/general/Workflow/overview.md","sourceDirName":"general/Workflow","slug":"/general/Workflow/workflow-overview","permalink":"/promptbio-wiki/docs/general/Workflow/workflow-overview","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"workflow-overview","title":"Workflow Overview","sidebar_position":1},"sidebar":"generalSidebar","previous":{"title":"Omics Overview","permalink":"/promptbio-wiki/docs/general/Omics/omics-overview"}},{"id":"intro","title":"Welcome to PromptBio Wiki","description":"PromptBio is a platform for biological data analysis powered by AI. This wiki covers everything you need to get started — from project setup to advanced analysis workflows.","source":"@site/docs/intro.md","sourceDirName":".","slug":"/intro","permalink":"/promptbio-wiki/docs/intro","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"id":"intro","title":"Welcome to PromptBio Wiki","sidebar_position":1},"sidebar":"generalSidebar","next":{"title":"Getting Started","permalink":"/promptbio-wiki/docs/general/Home/getting-started"}},{"id":"technical/api-reference","title":"API Reference","description":"The PromptBio REST API lets you programmatically interact with projects, data, and analyses.","source":"@site/docs/technical/api-reference.md","sourceDirName":"technical","slug":"/technical/api-reference","permalink":"/promptbio-wiki/docs/technical/api-reference","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"id":"api-reference","title":"API Reference","sidebar_position":2},"sidebar":"technicalSidebar","previous":{"title":"Technical Overview","permalink":"/promptbio-wiki/docs/technical/"}},{"id":"technical/technical-overview","title":"Technical Documentation","description":"This section covers the technical internals of PromptBio — API references, architecture details, and integration guides for developers.","source":"@site/docs/technical/index.md","sourceDirName":"technical","slug":"/technical/","permalink":"/promptbio-wiki/docs/technical/","draft":false,"unlisted":false,"tags":[],"version":"current","sidebarPosition":1,"fr